<aside class="om-sidebar">

  <div class="om-sidebar-logo">
    <%= link_to root_path do %>
      &lt;OpenMines /&gt;
    <% end %>
  </div>

  <div class="om-sidebar-section">
    <div class="om-sidebar-label">// navigation</div>
    <ul class="om-sidebar-nav">
      <li>
        <%= link_to root_path, class: "#{controller_name == 'pages' ? 'active' : ''}" do %>
          <span class="prefix">→</span> home()
        <% end %>
      </li>
      <li>
        <%= link_to new_game_path, class: "#{action_name == 'new' && controller_name == 'games' ? 'active' : ''}" do %>
          <span class="prefix">+</span> new_game()
        <% end %>
      </li>
    </ul>
  </div>

  <% if authenticated? && @games.present? %>
    <div class="om-sidebar-section">
      <div class="om-sidebar-label">// games[]</div>
      <div class="om-sidebar-game">
        <% @games.each do |game| %>
          <%= link_to game_path(game), class: "om-sidebar-game-item" do %>
            <span class="om-sidebar-game-dot dot-<%= game.status %>"></span>
            <span style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex:1">
              <%= game.name.presence || "game_#{game.id}" %>
            </span>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>

  <div class="om-sidebar-footer">
    <% if authenticated? %>
      <div class="om-sidebar-user">
        <span style="color:var(--fg-muted)">user:</span>
        <span><%= Current.session.user.first_name %></span>
      </div>
      <%= link_to "sign_out()", logout_path,
            data: { turbo_confirm: "Are you sure?" },
            style: "font-size:11px; color:var(--fg-muted);" %>
    <% else %>
      <ul class="om-sidebar-nav">
        <li><%= link_to new_session_path do %><span class="prefix">→</span> login()<% end %></li>
        <li><%= link_to new_registration_path do %><span class="prefix">+</span> register()<% end %></li>
      </ul>
    <% end %>
  </div>

</aside>
